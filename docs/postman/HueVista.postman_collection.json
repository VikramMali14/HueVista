            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"projectId\": \"{{projectId}}\",\n  \"retailerId\": \"{{retailerOrgId}}\",\n  \"painterId\": \"{{painterUserId}}\",\n  \"siteAddress\": \"12 Vidya Nagar, Belgavi 590001\",\n  \"estimatedAreaSqft\": 420.0,\n  \"estimatedPaintLiters\": 7.0,\n  \"notes\": \"Two coats throughout. Trim in royale.\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/jobs", "host": ["{{baseUrl}}"], "path": ["api", "jobs"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "if (pm.response.code === 201) {",
              "  const r = pm.response.json();",
              "  pm.environment.set('jobId', r.id);",
              "}"
            ]}
          }]
        },
        {
          "name": "Get job",
