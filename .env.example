# ============================================================================
#  HueVista backend — environment variables
#  Copy to `.env` (or set these in your host/orchestrator) for production.
#  The app reads them via ${VAR} placeholders in application.properties.
#  For LOCAL dev you don't need any of this — run with the `dev` profile:
#     ./mvnw spring-boot:run -Dspring-boot.run.profiles=dev
#  Schema is managed by Hibernate ddl-auto=update (no Flyway).
# ============================================================================

# --- Core ---
JWT_SECRET=                      # REQUIRED (no default anywhere). Base64, 32+ bytes. Generate: openssl rand -base64 32
APP_BASE_URL=https://api.your-domain.com   # used for share links
CORS_ALLOWED_ORIGINS=https://app.your-domain.com   # comma-separated frontend origins

# --- Hardening toggles ---
SWAGGER_ENABLED=false            # Swagger UI + /v3/api-docs are public; enable only in dev
RATE_LIMIT_TRUST_FORWARDED=true  # set false if the backend port is ever exposed directly
                                 # (stops X-Forwarded-For spoofing of the per-IP limits)

# --- PostgreSQL (production datasource) ---
DB_PASSWORD=
# (host/db/user are set in application.properties: jdbc:postgresql://localhost:5432/huevista, user postgres)

# --- Google OAuth2 (optional; enables "Continue with Google") ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Claude / Anthropic (image classification, shade enrichment, recommendations) ---
ANTHROPIC_API_KEY=

# --- Replicate (auto wall-segmentation + image cleaner). OFF unless enabled. ---
REPLICATE_API_TOKEN=
REPLICATE_NANO_BANANA_ENABLED=false
REPLICATE_IMAGE_CLEANER_ENABLED=false

# --- AWS S3 (image/mask storage). Blank bucket = local filesystem. ---
S3_BUCKET_NAME=
S3_REGION=ap-south-1
UPLOAD_PATH=/var/huevista/uploads   # local storage path when S3 is unset

# --- Redis (async segmentation queue + cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Razorpay (subscriptions + one-time project credits) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PROFESSIONAL=
RAZORPAY_PLAN_BUSINESS=
PROJECT_CREDIT_AMOUNT_PAISE=4900
PROJECT_CREDIT_CURRENCY=INR

# --- Email (verification + password-reset codes). Blank host = log to console. ---
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@your-domain.com

# --- SMS (mobile verification codes). console in dev; wire a provider in SmsSender. ---
SMS_ENABLED=false
SMS_PROVIDER=console

# --- Support channels (all optional) ---
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=             # verifies X-Hub-Signature-256 on inbound webhooks
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=       # verifies the ElevenLabs-Signature on webhooks
