# ============================================================================
#  HueVista backend — environment variables
#  Copy to `.env` (or set these in your host/orchestrator) for production.
#  The app reads them via ${VAR} placeholders in application.properties.
#
#  For LOCAL dev you don't need ANY of this — run with the `dev` profile:
#     ./mvnw spring-boot:run -Dspring-boot.run.profiles=dev
#  Schema is managed by Hibernate ddl-auto=update (no Flyway).
#
#  Grouped by priority:
#    [REQUIRED] the app won't run / shouldn't go to prod without these
#    [CORE]     powers the main product (AI paint visualizer + image storage)
#    [OPTIONAL] feature-gated add-ons — leave blank and that feature stays off
# ============================================================================


# ============================================================================
#  [REQUIRED]  — set these before any production deploy
# ============================================================================

# Self-generated, NOT a third-party key. Base64, 32+ bytes. No default anywhere.
#   Generate: openssl rand -base64 32
JWT_SECRET=

# PostgreSQL password (host/db/user are fixed in application.properties:
#   jdbc:postgresql://localhost:5432/huevista, user "postgres").
DB_PASSWORD=

# Public URL of THIS backend — used for share links.
APP_BASE_URL=https://api.your-domain.com
# Comma-separated list of allowed frontend origins (CORS).
CORS_ALLOWED_ORIGINS=https://app.your-domain.com

# Admin bootstrap: on startup, a single ROLE_ADMIN with these credentials is
# seeded IF both are set and no such account exists. The admin provisions every
# shop account and receives shop-lead notifications — without one the platform
# can't be operated. Change the password after first sign-in.
ADMIN_EMAIL=
ADMIN_PASSWORD=


# ============================================================================
#  [CORE]  — the main product features
# ============================================================================

# --- Anthropic / Claude  (REQUIRED for the AI product) -----------------------
# Powers image classification, shade enrichment, color recommendations and the
# support agent. Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- AWS S3  (image/mask storage) --------------------------------------------
# Blank bucket = store on the local filesystem instead (UPLOAD_PATH below).
# Credentials come from the instance IAM role (no access keys needed here).
S3_BUCKET_NAME=
S3_REGION=ap-south-1
UPLOAD_PATH=/var/huevista/uploads   # local storage path when S3 is unset

# --- Redis  (cache + async wall-segmentation queue) --------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Replicate  (auto wall-segmentation + image cleaner) ---------------------
# OFF unless enabled; when off, the UI falls back to manual click-to-segment.
# Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
REPLICATE_NANO_BANANA_ENABLED=false
REPLICATE_IMAGE_CLEANER_ENABLED=false
# Cleaner generation resolution (Nano Banana Pro: 1K/2K/4K; blank to omit) and the
# local longest-edge upscale target in px (3840 ≈ 4K; 0 to disable upscaling).
REPLICATE_IMAGE_CLEANER_RESOLUTION=1K
REPLICATE_IMAGE_CLEANER_UPSCALE_PX=3840


# ============================================================================
#  [OPTIONAL]  — feature-gated add-ons (blank = that feature is disabled)
# ============================================================================

# --- Google OAuth2  ("Continue with Google" login) ---------------------------
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Razorpay  (subscriptions + one-time project credits) --------------------
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_STARTER=
RAZORPAY_PLAN_PROFESSIONAL=
RAZORPAY_PLAN_BUSINESS=
PROJECT_CREDIT_AMOUNT_PAISE=4900
PROJECT_CREDIT_CURRENCY=INR

# --- Email  (verification + password-reset codes) ----------------------------
# Blank host = codes are logged to the console instead of emailed.
# NOTE: MAIL_ENABLED / SMS_ENABLED also drive the retailer verification gate —
# a channel is only REQUIRED-verified before project creation when it can
# actually deliver a code. Production should enable BOTH for the full gate.
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@your-domain.com

# --- SMS  (mobile verification codes) ----------------------------------------
# provider=console (default) just logs the code. For real texts:
#   SMS_ENABLED=true and SMS_PROVIDER=twilio, then fill the three Twilio creds.
# Twilio console: https://console.twilio.com
SMS_ENABLED=false
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=          # sender number / Messaging Service SID, e.g. +14155552671

# --- WhatsApp Cloud API (Meta)  (support channel) ----------------------------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=          # verifies X-Hub-Signature-256 on inbound webhooks

# --- ElevenLabs  (voice support agent) ---------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_WEBHOOK_SECRET=    # verifies the ElevenLabs-Signature on webhooks

# --- Hardening toggles -------------------------------------------------------
SWAGGER_ENABLED=false            # Swagger UI + /v3/api-docs are public; dev only
RATE_LIMIT_TRUST_FORWARDED=true  # set false if the backend port is exposed directly
                                 # (stops X-Forwarded-For spoofing of per-IP limits)

# --- Abuse limits (per-IP; sensible defaults, override only if needed) -------
RATE_LIMIT_IMAGE_UPLOAD_MAX=30   # uploads/hour — each triggers a paid Claude classification
RATE_LIMIT_LEAD_MAX=5            # shop-account requests/hour (public form anti-spam)

# --- Monitoring (Prometheus) --------------------------------------------------
# Expose /actuator/prometheus (JVM, HTTP, Hikari, cache metrics) and open it to
# anonymous scrapes. ONLY do this when the backend port is private-network-only.
ACTUATOR_EXPOSURE=health         # set to: health,prometheus
METRICS_PUBLIC=false             # set true so the scraper can reach it without a JWT

# --- Timezone ------------------------------------------------------------------
# Timestamps are stored zone-naive (LocalDateTime) and the product is India-only.
# Keep the JVM on IST (the Docker image pins this) or every expiry shifts.
TZ=Asia/Kolkata
